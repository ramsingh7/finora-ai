ENV=development
GRPC_HOST=0.0.0.0
GRPC_PORT=50051
LOG_LEVEL=info
DATA_DIR=./data
MAX_UPLOAD_MB=32
SHUTDOWN_GRACE_SECONDS=15
GRPC_REFLECTION=true
GRPC_MAX_RECV_MB=4
GRPC_MAX_SEND_MB=4

# PostgreSQL (optional locally; required in production via config.Validate)
DATABASE_URL=postgres://finora:finora@localhost:5432/finora?sslmode=disable

# Redis (optional)
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT HS256 — set a long random secret; min 32 chars in production
JWT_SECRET=
JWT_ISSUER=finora-backend
JWT_EXPIRE_MINUTES=60
